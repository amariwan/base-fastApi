############################################################
# CORE
###########################################################
API_PREFIX=/api/v1
LOG_LEVEL=INFO
TEST_MODE=false
PROFILING_ENABLED=false
PYTHONPATH=src


############################################################
# AUTHENTICATION & ROLE MANAGEMENT
############################################################
AUTH_MODE=jwks
AUTH_ROLE_PREFIX=GRPS_Portal_DocuFlowTest_

ROLES_ACTIVE=true
ROLES_READ=KassenUser
ROLES_WRITE=VertragsManagerVerguetungsvereinbarung
ROLES_DELETE=VertragsadministratorKasse
ROLES_ADMIN=Admin
AUTH_MANDANT_CLAIM=organisation

# JWKS / OpenID Provider (only used when AUTH_MODE=jwks)
AUTH_JWKS_URL=https://domain.com/realms/DevRealm/protocol/openid-connect/certs
AUTH_ISSUER=https://domain.com/realms/DevRealm
AUTH_AUDIENCE=my-service
AUTH_ALGORITHMS=RS256
AUTH_VALIDATE_SIGNATURE=false

# HMAC (only used when AUTH_MODE=hs)
AUTH_HS_SECRET=

# Verification flags
AUTH_VERIFY_SIGNATURE=false
AUTH_VERIFY_EXP=false
AUTH_VERIFY_ISS=false
AUTH_VERIFY_AUD=false
AUTH_CLOCK_SKEW_SECS=60

############################################################
# HTTP LOGGING
############################################################
HTTP_LOGGING_ENABLED=true
HTTP_REQUEST_LOGGING_ENABLED=false
HTTP_RESPONSE_LOGGING_ENABLED=false
HTTP_FAULT_LOGGING_ENABLED=true

############################################################
# SECURITY HEADERS
############################################################
SECURITY_HEADERS_ENABLED=true
SECURITY_HEADERS_HSTS_ENABLED=false
SECURITY_HEADERS_HSTS_MAX_AGE=31536000
SECURITY_HEADERS_CSP_ENABLED=false
SECURITY_HEADERS_CSP_DIRECTIVES=
SECURITY_HEADERS_X_FRAME_OPTIONS=

############################################################
# REQUEST LIMITS (bytes)
############################################################
MAX_REQUEST_SIZE_BYTES=10485760
MAX_UPLOAD_SIZE_BYTES=52428800
MAX_FILE_SIZE_MB=50

# Template placeholder detection mode:
# - jinja_only: only {{ var }}
# - jinja_and_single_curly: {{ var }} and { var }
# - extended: {{ var }}, { var }, [var], [[var]]
VALIDATION_PLACEHOLDER_MODE=extended


############################################################
# STORAGE BACKEND
############################################################
STORAGE_BACKEND=s3
S3_ENDPOINT=https://domain.com:9000
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=dev-app-storage
S3_REGION=us-east-1
S3_SECURE=true
S3_ADDRESSING_STYLE=path


############################################################
# DATABASE (optional; required only if DB_ENABLED=true)
############################################################
DB_ENABLED=false
DB_IP=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=docgen
DB_ENGINE_ECHO=false
DB_AUTO_CREATE_TABLES=false
